// ====================== 默认变量 ======================
let sitename = "域名监控";
let tgid = "";
let tgtoken = "";
let days = 7;

// ====================== 发送 Telegram 消息 ======================
async function sendtgMessage(message, tgid, tgtoken) {
  if (!tgid || !tgtoken) return;
  const url = `https://api.telegram.org/bot${tgtoken}/sendMessage`;
  const params = { 
    chat_id: tgid, 
    text: message, 
    parse_mode: "HTML" 
  };

  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(params),
    });
    if (!res.ok) console.error('Telegram 发送失败:', await res.text());
  } catch (error) {
    console.error('Telegram 消息推送失败:', error);
  }
}

export default {
  async fetch(request, env) {
    sitename = env.SITENAME || sitename;
    tgid = env.TGID || tgid;
    tgtoken = env.TGTOKEN || tgtoken;
    days = parseInt(env.DAYS || days, 10) || 7;
    const PASSWORD = env.PASSWORD || "";

    const url = new URL(request.url);
    let path = url.pathname;
    if (path === '' || path === '/') path = '/';

    // ====================== favicon 处理 ======================
    if (path === '/favicon.ico') {
      return new Response(null, { status: 204 });
    }

    // ====================== 密码保护（使用你提供的严格逻辑） ======================
    if (PASSWORD) {
      const cookieHeader = request.headers.get('cookie') || '';
      const isAuthenticated = cookieHeader.includes(`domain_auth=${PASSWORD}`);

      // 1. 处理登录提交
      if (path === '/login' && request.method === 'POST') {
        const formData = await request.formData();
        if (formData.get('password') === PASSWORD) {
          return new Response('', {
            status: 302,
            headers: {
              'Set-Cookie': `domain_auth=${PASSWORD}; Path=/; Max-Age=86400; HttpOnly; Secure; SameSite=Strict`,
              'Location': '/',
            },
          });
        } else {
          // 密码错误，直接返回登录页并中断
          return new Response(generateLoginHTML(sitename, true), {
            headers: { 'Content-Type': 'text/html; charset=utf-8' },
          });
        }
      }

      // 2. 未登录则拦截一切请求
      if (!isAuthenticated) {
        if (path.startsWith('/api/')) {
          return new Response(JSON.stringify({ success: false, message: '未授权访问' }), {
            status: 401,
            headers: { 'Content-Type': 'application/json' },
          });
        }
        // 普通页面请求返回登录页
        return new Response(generateLoginHTML(sitename, false), {
          headers: { 'Content-Type': 'text/html; charset=utf-8' },
        });
      }
    }

    // ====================== API 接口 ======================
    if (path === '/api/domains') {
      if (request.method === 'GET') {
        const data = await getDomainsData(env);
        return new Response(JSON.stringify(data), {
          headers: { 'Content-Type': 'application/json' },
        });
      }

      if (request.method === 'POST') {
        const body = await request.json();
        const { action, index, domainData, newOrder } = body;

        let domainsData = await getDomainsData(env);

        if (action === 'reorder' && newOrder) {
          const orderedData = newOrder.map(key => 
            domainsData.find(item => item.domain === key)
          ).filter(Boolean);
          await saveDomainsData(env, orderedData);
          return new Response(JSON.stringify({ success: true }));
        }

        if (action === 'save' || action === 'add') {
          if (!domainData.domain || !domainData.system || !domainData.systemURL || 
              !domainData.registrationDate || !domainData.expirationDate) {
            return new Response(JSON.stringify({ success: false, message: '除特别说明外，所有字段不能为空' }), { status: 400 });
          }
          if (!isValidDate(domainData.registrationDate) || !isValidDate(domainData.expirationDate)) {
            return new Response(JSON.stringify({ success: false, message: '注册时间和过期时间必须是有效日期格式 (YYYY-MM-DD)' }), { status: 400 });
          }

          if (action === 'add') {
            domainsData.push(domainData);
          } else if (action === 'save' && typeof index === 'number') {
            domainsData[index] = domainData;
          }
        } else if (action === 'delete' && typeof index === 'number') {
          domainsData.splice(index, 1);
        } else {
          return new Response(JSON.stringify({ success: false, message: '无效操作' }), { status: 400 });
        }

        await saveDomainsData(env, domainsData);
        return new Response(JSON.stringify({ success: true }));
      }
    }

    // ====================== 主页面 + TG 提醒 ======================
    if (path === '/') {
      const domainsData = await getDomainsData(env);
      const today = new Date().toISOString().split('T')[0];

      for (const domain of domainsData) {
        const expirationDate = new Date(domain.expirationDate);
        const daysRemaining = Math.ceil((expirationDate - Date.now()) / (1000 * 60 * 60 * 24));

        if (daysRemaining > 0 && daysRemaining <= days) {
          const message = `⚠️ <b>域名到期提醒</b>\n\n域名：${domain.domain}\n将在 <b>${daysRemaining}</b> 天后过期\n过期日期：${domain.expirationDate}`;
          const lastSentDate = await env.DOMAINS_TG_KV?.get(domain.domain);

          if (lastSentDate !== today) {
            await sendtgMessage(message, tgid, tgtoken);
            if (env.DOMAINS_TG_KV) await env.DOMAINS_TG_KV.put(domain.domain, today, { expirationTtl: 172800 });
          }
        }
      }

      const htmlContent = generateHTML(domainsData, sitename, !!PASSWORD);
      return new Response(htmlContent, {
        headers: { 'Content-Type': 'text/html; charset=utf-8' },
      });
    }

    // ====================== 兜底：未知路径返回首页 ======================
    const domainsData = await getDomainsData(env);
    const htmlContent = generateHTML(domainsData, sitename, !!PASSWORD);
    return new Response(htmlContent, {
      headers: { 'Content-Type': 'text/html; charset=utf-8' },
    });
  }
};

// ====================== KV 操作 ======================
async function getDomainsData(env) {
  if (!env.DOMAINS_KV) return [];
  const data = await env.DOMAINS_KV.get('domains', 'json');
  return Array.isArray(data) ? data : [];
}

async function saveDomainsData(env, data) {
  if (!env.DOMAINS_KV) throw new Error('DOMAINS_KV 未绑定');
  await env.DOMAINS_KV.put('domains', JSON.stringify(data));
}

function isValidDate(dateStr) {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return false;
  const date = new Date(dateStr);
  return date instanceof Date && !isNaN(date.getTime());
}

