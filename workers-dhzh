export default {
  async fetch(request, env, ctx) {
    const html = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>导航书签转换器</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; }
        /* 自定义滚动条样式 */
        #previewContent::-webkit-scrollbar { width: 4px; }
        #previewContent::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="max-w-5xl mx-auto p-3 sm:p-6">
        <div class="bg-white rounded-2xl sm:rounded-3xl shadow-xl p-4 sm:p-8">
            <!-- 标题栏 -->
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 sm:mb-10 gap-3">
                <div>
                    <h1 class="text-2xl sm:text-4xl font-bold text-gray-900">导航书签转换器</h1>
                    <p class="text-gray-500 text-sm mt-1">Read • SunPanel • Workers 三格式互转</p>
                </div>
                <div class="text-xs bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full font-medium">Cloudflare Workers</div>
            </div>

            <!-- 📥 导入区域 -->
            <div class="mb-8">
                <h2 class="text-lg sm:text-2xl font-semibold mb-4 flex items-center gap-2">📥 导入文件</h2>
                <div class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-12 gap-3">
                        <div class="sm:col-span-4">
                            <label class="block text-xs font-medium text-gray-500 mb-1 ml-1">导入格式</label>
                            <select id="importType" class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all bg-gray-50">
                                <option value="read">Read (Legado导航)</option>
                                <option value="sunpanel">SunPanel</option>
                                <option value="workers">Workers (testUser)</option>
                            </select>
                        </div>
                        <div class="sm:col-span-8">
                            <label class="block text-xs font-medium text-gray-500 mb-1 ml-1">选择文件</label>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <input type="file" id="fileInput" accept="*/*" 
                                       class="flex-1 text-sm file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 border border-gray-200 rounded-xl p-1 bg-gray-50">
                                <button onclick="handleImport()" 
                                       class="w-full sm:w-auto px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-medium shadow-md transition-all active:scale-95">
                                    导入解析
                                </button>
                            </div>
                        </div>
                    </div>
                    <div id="importStatus" class="min-h-[20px] text-xs font-medium px-1"></div>
                </div>
            </div>

            <!-- 预览区域 -->
            <div id="previewSection" class="hidden mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="text-lg font-semibold flex items-center gap-2">预览内容</h2>
                    <span id="totalCount" class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full"></span>
                </div>
                <div id="previewContent" class="max-h-[300px] sm:max-h-[420px] overflow-auto border border-gray-100 rounded-2xl p-4 bg-gray-50/50 shadow-inner">
                </div>
            </div>

            <!-- 📤 导出区域 -->
            <div>
                <h2 class="text-lg sm:text-2xl font-semibold mb-4 flex items-center gap-2">📤 导出文件</h2>
                <div class="p-4 bg-gray-50 rounded-2xl border border-gray-100 space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-gray-500 mb-2 ml-1">目标格式</label>
                        <select id="exportType" class="w-full px-3 py-2.5 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all bg-white">
                            <option value="read">Read - read.json (阅读书签格式)</option>
                            <option value="sunpanel">SunPanel - .sun-panel.json (官方导入格式)</option>
                            <option value="workers">Workers - testUser.txt (Workers导航格式)</option>
                        </select>
                    </div>
                    <button onclick="handleExport()" 
                            class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl font-medium shadow-md transition-all active:scale-95 text-sm">
                        生成并下载
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentData = null;

        function normalizeData(source, type) {
            let groups = [];
            if (type === 'read') {
                const sortUrl = source.sortUrl || "";
                const groupBlocks = sortUrl.split(/\\n\\s*\\n/);
                groupBlocks.forEach(block => {
                    const lines = block.trim().split('\\n');
                    if (lines.length === 0) return;
                    let groupTitle = "未分类";
                    let items = [];
                    lines.forEach(line => {
                        line = line.trim();
                        if (!line) return;
                        if (line.includes('::')) {
                            groupTitle = line.split('::')[0].replace(/[\\u2700-\\u2bef\\ud83c\\ud83d\\ud83e\\u2100-\\u2dff]/g, '').trim();
                        } else {
                            const cardMatches = line.match(/(https?:\\/\\/[^\\s【《]+(【.*?】)?(《.*?》)?(◎.*?◎)?)/g);
                            if (cardMatches) {
                                cardMatches.forEach(card => {
                                    const url = (card.match(/(https?:\\/\\/[^\\s【《◎]+)/) || [])[1];
                                    const icon = (card.match(/【(.*?)】/) || [])[1] || "";
                                    const name = (card.match(/《(.*?)》/) || [])[1] || "未知";
                                    const desc = (card.match(/◎(.*?)◎/) || [])[1] || "";
                                    if (url) items.push({ name, url, icon, desc });
                                });
                            }
                        }
                    });
                    if (items.length > 0) groups.push({ title: groupTitle, items });
                });
            } else if (type === 'sunpanel') {
                (source.icons || []).forEach(g => {
                    groups.push({
                        title: g.title,
                        items: (g.children || []).map(item => ({
                            name: item.title, url: item.url,
                            icon: item.icon?.src || '', desc: item.description || ''
                        }))
                    });
                });
            } else if (type === 'workers') {
                const map = {};
                (source.links || []).forEach(link => {
                    const cat = link.category || '未分类';
                    if (!map[cat]) map[cat] = [];
                    map[cat].push({
                        name: link.name, url: link.url,
                        icon: link.icon || '', desc: link.tips || ''
                    });
                });
                Object.keys(map).forEach(key => groups.push({title: key, items: map[key]}));
            }
            return { groups };
        }

        function getIcon(title) {
            const iconMap = {
                "导": "💠 ", "工": "🛠️ ", "设": "🛠️ ", "存": "🎄", 
                "云": "🎄", "盘": "🎄", "视": "🎬 ", "影": "🎬 ", 
                "剧": "🎬 ", "搜": "🔍 ", "网": "👀 ", "站": "👀 ", 
                "社": "💬 ", "交": "💬 ", "乐": "🎵 ", "曲": "🎵 ", 
                "图": "🎨 ", "画": "🎨 ", "文": "📚 ", "学": "📚 "
            };
            for (let key in iconMap) {
                if (title.indexOf(key) !== -1) return iconMap[key];
            }
            return "📂 ";
        }

        function convertToRead(data) {
            let sortUrlArr = [];
            data.groups.forEach(group => {
                let groupStr = getIcon(group.title) + group.title + "::";
                let itemsStr = group.items.map(item => {
                    let finalUrl = item.url.trim();
                    if (!finalUrl.endsWith('/')) { finalUrl += '/'; }
                    let finalIcon = (item.icon || '').trim();
                    if (!finalIcon) {
                        finalIcon = finalUrl + 'favicon.ico';
                        finalIcon = finalIcon.replace(/([^:])\\/\\//g, '$1/');
                    }
                    finalIcon = finalIcon.replace(/\\s+/g, '');
                    let finalName = (item.name || '').replace(/\\s+/g, '');
                    let finalDesc = (item.desc || '').replace(/\\s+/g, '');
                    return finalUrl + "【" + finalIcon + "】《" + finalName + "》◎" + finalDesc + "◎";
                }).join(" ");
                sortUrlArr.push(groupStr + itemsStr);
            });
            return {
                "articleStyle": 0, "customOrder": 9, "enableJs": true, "enabled": true, "enabledCookieJar": false,
                "header": "{\\n    'User-Agent': 'Mozilla/5.0 ... SearchCraft/3.9.2 (Baidu; P1 11) '\\n}",
                "lastUpdateTime": 0, "loadWithBaseUrl": true,
                "ruleArticles": "<js>\\njson=[];\\nif(baseUrl.match(/ /)){\\nlist=baseUrl.replace(/http.*?wd=\\\\s*/,'').split(' ');\\nfor(i in list){\\nif(!list[i].includes('【')) continue;\\nlet itemStr = list[i];\\nhref=itemStr.match(/【(.*?)】/)[1];\\ntext=itemStr.match(/《(.*?)》/)[1];\\nintro=itemStr.match(/◎(.*?)◎/)[1];\\nlet m = itemStr.match(/^(\\\\d+、\\\\d+、)/);\\nindex = m ? m[1] : itemStr.match(/^(.*?)【/)[1];\\njson.push({text:text,src:href,intro:intro,index:index})\\n}\\n}\\nJSON.stringify(json)</js>\\n$.[*]",
                "ruleImage": "$.src", "ruleLink": "$.index\\n@js:\\nif(!result.match(/^http/) && !result.match(/\\\\d+、\\\\d+、/)){\\nresult=\\"https://www.coolapk.com/link?url=\\"+encodeURIComponent(result)\\n}else{result=result}",
                "rulePubDate": "$.intro", "ruleTitle": "$.text", "singleUrl": false,
                "sortUrl": sortUrlArr.join("\\n\\n"), "sourceGroup": "转入导航", "sourceIcon": "https://tk.ttanzj.us.ci/i/131/OIP.webp",
                "sourceName": "阅读导航", "sourceUrl": ""
            };
        }

        function convertToSunPanel(data) {
            const icons = data.groups.map((group, idx) => ({
                title: group.title,
                sort: idx * 10,
                children: group.items.map((item, i) => ({
                    icon: { itemType: 2, src: item.icon || '', text: "", backgroundColor: "" },
                    sort: i, title: item.name, url: item.url, description: item.desc,
                    openMethod: 2, cardType: 1, lanUrl: "", backgroundColor: "#2a2a2a6b", expandParam: {}
                }))
            }));
            return { version: 1, appName: "Sun-Panel-Config", exportTime: new Date().toISOString(), appVersion: "1.8.1", md5: "", icons: icons };
        }

        function convertToWorkers(data) {
            const links = [];
            const categories = {};
            data.groups.forEach(group => {
                categories[group.title] = [];
                group.items.forEach(item => {
                    const linkObj = { name: item.name, url: item.url, tips: item.desc, icon: item.icon, category: group.title, isPrivate: false };
                    links.push(linkObj);
                    categories[group.title].push(linkObj);
                });
            });
            return { links, categories };
        }

        async function handleImport() {
            const fileInput = document.getElementById('fileInput');
            const importType = document.getElementById('importType').value;
            const status = document.getElementById('importStatus');
            if (!fileInput.files.length) {
                status.innerHTML = '<span class="text-red-500">❌ 请先选择文件</span>';
                return;
            }
            try {
                const text = await fileInput.files[0].text();
                const source = JSON.parse(text);
                currentData = normalizeData(source, importType);
                let html = '';
                let totalLinks = 0;
                currentData.groups.forEach(group => {
                    html += '<div class="mb-6">';
                    html += '<div class="font-bold text-base mb-3 flex items-center gap-2 text-gray-800 border-l-4 border-blue-500 pl-3">' + group.title + '<span class="text-[10px] font-normal text-gray-400 bg-gray-100 px-2 py-0.5 rounded">' + group.items.length + '项</span></div>';
                    html += '<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">';
                    group.items.forEach(item => {
                        totalLinks++;
                        const defaultIcon = 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23ccc"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>';
                        html += '<div class="flex items-center gap-3 p-3 bg-white border border-gray-100 rounded-xl shadow-sm">';
                        html += '<img src="' + (item.icon || defaultIcon) + '" class="w-8 h-8 rounded-lg object-cover" onerror="this.src=\\'' + defaultIcon + '\\\'">';
                        html += '<div class="flex-1 min-w-0"><div class="font-bold text-gray-900 text-sm truncate">' + item.name + '</div>';
                        html += '<div class="text-[10px] text-gray-400 truncate">' + item.url + '</div></div></div>';
                    });
                    html += '</div></div>';
                });
                document.getElementById('previewContent').innerHTML = html;
                document.getElementById('totalCount').innerText = '共计 ' + totalLinks + ' 个书签';
                document.getElementById('previewSection').classList.remove('hidden');
                status.innerHTML = '<span class="text-emerald-600">✅ 解析成功</span>';
            } catch (error) {
                status.innerHTML = '<span class="text-red-500">❌ 解析失败：' + error.message + '</span>';
            }
        }

        function handleExport() {
            if (!currentData) { alert('请先导入并解析文件'); return; }
            const type = document.getElementById('exportType').value;
            let result, filename, mimeType;
            if (type === 'read') {
                result = convertToRead(currentData); filename = 'read.json'; mimeType = 'application/json';
            } else if (type === 'sunpanel') {
                result = convertToSunPanel(currentData); filename = 'SunPanel.sun-panel.json'; mimeType = 'application/json';
            } else {
                result = convertToWorkers(currentData); filename = 'testUser.txt'; mimeType = 'text/plain';
            }
            const blob = new Blob([JSON.stringify(result, null, 2)], {type: mimeType + ';charset=utf-8'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = filename; a.click();
        }
    </script>
</body>
</html>`;

    return new Response(html, {
      headers: {
        "content-type": "text/html;charset=UTF-8",
      },
    });
  },
};
