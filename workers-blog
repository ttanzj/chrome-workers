export default {
  async fetch(req, env) {
    const url = new URL(req.url);
    const method = req.method;
    const PASSWORD = env.PASSWORD;

    const html = (b) =>
      new Response(`<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">${b}</html>`, { 
        headers: { "content-type": "text/html;charset=UTF-8" } 
      });

    const redirect = (to) =>
      new Response(null, { status: 302, headers: { Location: to } });

    const isLogin = () =>
      req.headers.get("cookie")?.includes("login=1");

    /* ---------- 登录 ---------- */
    if (url.pathname === "/login") {
      if (method === "POST") {
        const f = await req.formData();
        if (f.get("password") === PASSWORD) {
          return new Response("", {
            status: 302,
            headers: {
              "Set-Cookie": "login=1; Path=/; SameSite=Lax",
              Location: "/",
            },
          });
        }
        return html(loginPage("密码错误"));
      }
      return html(loginPage());
    }
    if (!isLogin()) return redirect("/login");

    /* ---------- 新建 ---------- */
    if (url.pathname === "/create" && method === "POST") {
      const f = await req.formData();
      const now = new Date().toISOString();
      const result = await env.DB.prepare(
        `INSERT INTO docs (title, category, tags, content, pinned, created_at, updated_at)
         VALUES (?, ?, ?, ?, 0, ?, ?) RETURNING id`
      ).bind(
        f.get("title"),
        f.get("category"),
        f.get("tags"),
        f.get("content"),
        now,
        now
      ).first();
      return redirect(`/view?id=${result.id}`);
    }

    /* ---------- 切换置顶 ---------- */
    if (url.pathname === "/pin") {
      const id = url.searchParams.get("id");
      await env.DB.prepare(
        `UPDATE docs 
         SET pinned = CASE WHEN pinned = 1 THEN 0 ELSE 1 END,
             updated_at = ?
         WHERE id = ?`
      ).bind(new Date().toISOString(), id).run();
      return redirect("/");
    }

    /* ---------- 删除 ---------- */
    if (url.pathname === "/delete") {
      await env.DB.prepare(`DELETE FROM docs WHERE id=?`)
        .bind(url.searchParams.get("id")).run();
      return redirect("/");
    }

    /* ---------- 查看 ---------- */
    if (url.pathname === "/view") {
      const doc = await env.DB.prepare(`SELECT * FROM docs WHERE id=?`)
        .bind(url.searchParams.get("id")).first();
      return html(viewPage(doc));
    }

    /* ---------- 编辑 ---------- */
    if (url.pathname === "/edit") {
      const id = url.searchParams.get("id");
      if (method === "POST") {
        const f = await req.formData();
        await env.DB.prepare(
          `UPDATE docs SET title=?, category=?, tags=?, content=?, updated_at=?
           WHERE id=?`
        ).bind(
          f.get("title"),
          f.get("category"),
          f.get("tags"),
          f.get("content"),
          new Date().toISOString(),
          id
        ).run();
        return redirect(`/view?id=${id}`);
      }
      const doc = await env.DB.prepare(`SELECT * FROM docs WHERE id=?`)
        .bind(id).first();
      return html(editPage(doc));
    }

    /* ---------- 首页 ---------- */
    const categoryFilter = url.searchParams.get("category") || "";
    const docs = await env.DB.prepare(`
      SELECT * FROM docs 
      WHERE (? = '' OR category = ?)
      ORDER BY pinned DESC, updated_at DESC
    `).bind(categoryFilter, categoryFilter).all();

    const categories = await env.DB.prepare(
      `SELECT DISTINCT category FROM docs 
       WHERE category IS NOT NULL AND category != '' 
       ORDER BY category`
    ).all();

    return html(indexPage(docs.results, categories.results, categoryFilter));
  },
};

/* ================= 增强型表格解析 ================= */
function parseTables(text) {
  const lines = text.split('\n');
  let result = [];
  let i = 0;

  while (i < lines.length) {
    const trimmedLine = lines[i].trim();
    if (trimmedLine.startsWith('|') && i + 1 < lines.length && lines[i+1].includes('|') && lines[i+1].includes('-')) {
      let tableLines = [];
      while (i < lines.length && lines[i].trim().includes('|')) {
        tableLines.push(lines[i]);
        i++;
      }

      let tableHtml = `<table style="border-collapse:collapse;width:auto;max-width:100%;margin:0.5em 0;background:#fff;display:table;">`;
      const parseRow = (row) => row.split('|').filter((c, idx, arr) => (idx !== 0 && idx !== arr.length - 1) || c.trim());
      
      tableHtml += `<thead><tr>`;
      parseRow(tableLines[0]).forEach(c => {
        tableHtml += `<th style="border:1px solid #ddd;padding:6px 10px;background:#f8fafc;text-align:center;font-weight:550;">${c.trim()}</th>`;
      });
      tableHtml += `</tr></thead><tbody>`;
      
      for (let j = 2; j < tableLines.length; j++) {
        tableHtml += `<tr>`;
        parseRow(tableLines[j]).forEach(c => {
          tableHtml += `<td style="border:1px solid #ddd;padding:6px 10px;">${c.trim()}</td>`;
        });
        tableHtml += `</tr>`;
      }
      tableHtml += `</tbody></table>`;
      result.push(tableHtml);
    } else {
      result.push(lines[i]);
      i++;
    }
  }
  return result.join('\n');
}

/* ================= Markdown 解析 ================= */
function md(t) {
  if (!t) return "";
  const c = (tag) => `<\u002f${tag}>`;

  // 1. 保护转义字符
  let content = t.replace(/\\([*#_>`[\]()!|~-]+)/g, (m, p1) => {
    return p1.split('').map(char => `%%ESC_${char.charCodeAt(0)}%%`).join('');
  });

  // 2. 先进行全局转义
  content = escape(content);

  // 3. 还原特定实体，确保 &emsp; 这种不在正则处理中失效
  content = content.replace(/&amp;emsp;/g, '&emsp;');
  content = content.replace(/&lt;br\s*\/?&gt;/gi, '<br>');

  const codes = [];
  content = content.replace(/```([\s\S]*?)```/g, (m, p1) => {
    codes.push(p1);
    return `%%CODEBLOCK_${codes.length - 1}%%`;
  });

  content = parseTables(content);

  content = content
    .replace(/^\*\*\*$/gm, '<hr>')
    .replace(/^###### (.*$)/gm, `<h6>$1${c('h6')}`)
    .replace(/^##### (.*$)/gm, `<h5>$1${c('h5')}`)
    .replace(/^#### (.*$)/gm, `<h4>$1${c('h4')}`)
    .replace(/^### (.*$)/gm, `<h3>$1${c('h3')}`)
    .replace(/^## (.*$)/gm, `<h2>$1${c('h2')}`)
    .replace(/^# (.*$)/gm, `<h1>$1${c('h1')}`)
    .replace(/^&gt;[ ]?(.*$)/gm, `<blockquote>$1${c('blockquote')}`)
    .replace(/^\* (.*$)/gm, `<ul><li>$1${c('li')}${c('ul')}`)
    .replace(/^- (.*$)/gm, `<ul><li>$1${c('li')}${c('ul')}`)
    .split(`${c('ul')}\n<ul>`).join('');

  content = content
    .replace(/\*\*\*(.*?)\*\*\*/g, `<strong><em>$1${c('em')}${c('strong')}`)
    .replace(/\*\**(.*?)\*\*/g, `<strong>$1${c('strong')}`)
    .replace(/\*(.*?)\*/g, `<em>$1${c('em')}`)
    .replace(/~~(.*?)~~/g, `<del>$1${c('del')}`)
    .replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1">')
    .replace(/\[(.*?)\]\((.*?)\)/g, `<a href="$2" target="_blank">$1${c('a')}`)
    // 为单行代码添加类名以方便独立控制样式
    .replace(/`(.*?)`/g, `<code class="inline-code">$1${c('code')}`);

  const blockTags = 'h1|h2|h3|h4|h5|h6|ul|ol|li|blockquote|table|thead|tbody|tr|td|th|pre|hr|div';
  const lines = content.split('\n');
  const processedLines = lines.map((line, idx) => {
    const trimmed = line.trim();
    if (idx === lines.length - 1) return line;
    if (trimmed === "") return '<br class="blank-line">'; 
    if (new RegExp(`${c('(' + blockTags + ')')}$`, 'i').test(trimmed) || trimmed.endsWith('<br>')) return line;
    return line + '<br>';
  });
  
  content = processedLines.join('\n');
  content = content.replace(/%%CODEBLOCK_(\d+)%%/g, (m, p1) => `<pre><code>${codes[p1]}${c('code')}${c('pre')}`);
  content = content.replace(/%%ESC_(\d+)%%/g, (m, p1) => String.fromCharCode(p1));
  return content;
}

/* ================= 布局与样式 ================= */
function baseStyle() {
  const c = (tag) => `<\u002f${tag}>`;
  return `
<style>
:root { --primary: #2563eb; --bg: #f4f6f8; --text: #1f2937; }
body { margin: 0; font-family: -apple-system, system-ui, sans-serif; background: var(--bg); color: var(--text); -webkit-font-smoothing: antialiased; line-height: 1.5; font-size: 14.5px;letter-spacing: -0.01em; }
.container { max-width: 1000px; margin: 0 auto; padding: 20px; box-sizing: border-box; }
strong, b, h1, h2, h3, h4, h5, h6, .title, .header h2 { font-weight: 550; }

.view-content { min-height: 450px; word-wrap: break-word; }
.view-content p, .view-content div { margin: 0; }

/* 标题优化：行高随字号调整，减少上下间隙 */
.view-content h1 { font-size: 1.45rem; margin: 0.5em 0 0.2em 0; line-height: 1.2; }
.view-content h2 { font-size: 1.25rem; margin: 0.5em 0 0.2em 0; line-height: 1.2; }
.view-content h3 { font-size: 1.1rem; margin: 0.5em 0 0.2em 0; line-height: 1.2; }
.view-content h4, .view-content h5, .view-content h6 { margin: 0.4em 0 0.1em 0; line-height: 1.2; }

/* 直线优化：大幅压缩下方留白 */
.view-content hr { border: none; border-top: 1px solid #ddd; margin: 0.2em 0 0.05em 0; }

.view-content blockquote { border-left: 4px solid #ddd; padding: 4px 15px; margin: 0.4em 0; color: #666; background: #f9f9f9; }
.view-content ul { margin: 0.3em 0; padding-left: 1.5em; }

/* 代码引用样式：字体一致并添加阴影 */
.view-content code.inline-code { 
  font-family: inherit !important; 
  background: #f1f5f9; 
  padding: 2px 6px; 
  border-radius: 4px; 
  font-size: inherit;
  box-shadow: 1px 1px 3px rgba(0,0,0,0.12);
  margin: 0 2px;
}

/* 多行代码块：保持等宽字体 */
.view-content pre { background: #f1f5f9; padding: 12px; border-radius: 8px; overflow-x: auto; font-family: monospace; margin: 0.6em 0; font-size: 13.5px; }

.view-content table { border-spacing: 0; border: 1px solid #ddd; margin: 0.4em 0; }
.view-content img { max-width: 100%; height: auto; border-radius: 4px; display: block; margin: 0.2em 0; }

/* 换行控制 */
.view-content br { content: ""; display: block; margin-top: 0px; }
.view-content br.blank-line { margin-top: 8px; }

.login-wrapper { display: flex; align-items: center; justify-content: center; min-height: 100vh; width: 100%; box-sizing: border-box; }
.card { background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
.header h2 { margin: 0; font-size: 20px; }
button { padding: 8px 16px; font-size: 13.5px; border: none; border-radius: 8px; cursor: pointer; }
.btn-primary { background: var(--primary); color: #fff; }
.btn-ghost { background: #e5e7eb; color: #333; }
input, textarea { width: 100%; padding: 11px; font-size: 14.5px; margin-top: 8px; border-radius: 8px; border: 1px solid #d1d5db; box-sizing: border-box; }
textarea { min-height: 380px; line-height: 1.5; font-family: monospace; resize: vertical; }
.doc-item { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; transition: all 0.2s; overflow: hidden; }
.title { cursor: pointer; text-decoration: none; color: var(--text); }
.tag { background: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 4px; font-size: 11px; white-space: nowrap; }
.actions a { text-decoration: none; font-size: 17px; }
.list .doc-item { display: flex; align-items: center; padding: 10px 16px; gap: 12px; margin-bottom: 8px; }
.list .title-line { flex: 1; display: flex; align-items: center; gap: 8px; min-width: 0; }
.list .title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 14.5px; }
.list .actions { display: flex; gap: 15px; flex-shrink: 0; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 15px; }
.grid .doc-item { padding: 15px; display: flex; flex-direction: column; text-align: center; }
.grid .actions { margin-top: auto; padding-top: 12px; display: flex; justify-content: center; gap: 20px; }
.category-btn { padding: 5px 12px; border-radius: 20px; font-size: 12.5px; background: #fff; border: 1px solid #e2e8f0; text-decoration: none; color: inherit; }
.category-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
@media (max-width: 600px) { .container { padding: 10px; } .grid { grid-template-columns: 1fr 1fr; gap: 8px; } textarea { min-height: 300px; font-size: 14px; } }
</style>`;
}

function loginPage(msg="") {
  const c = (tag) => `<\u002f${tag}>`;
  return `${baseStyle()}
<div class="login-wrapper">
  <div class="card" style="width:100%; max-width:320px;">
    <h2 style="text-align:center; margin-bottom:20px">系统登录${c('h2')}
    ${msg ? `<p style="color:red;text-align:center;font-size:13.5px">${msg}${c('p')}` : ""}
    <form method="post">
      <input type="password" name="password" placeholder="密码" autofocus>
      <button class="btn-primary" style="width:100%;margin-top:16px;padding:12px">确认</button>
    </form>
  ${c('div')}
${c('div')}`;
}

function indexPage(docs, categories, currentCategory) {
  const c = (tag) => `<\u002f${tag}>`;
  const allCategories = [{category: ""}, ...categories];
  return `${baseStyle()}
<div class="container">
  <div class="header">
    <h2>📄 文档库${c('h2')}
    <div style="display:flex; gap:8px">
      <button class="btn-ghost" onclick="toggleLayout()">布局</button>
      <button class="btn-primary" onclick="toggleNew()">+ 新建</button>
    ${c('div')}
  ${c('div')}
  <div class="category-filter" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:15px;">
    ${allCategories.map(cat_obj => {
      const cat = cat_obj.category || "";
      const active = cat === currentCategory ? "active" : "";
      return `<a href="?category=${encodeURIComponent(cat)}" class="category-btn ${active}">${cat || "全部"}${c('a')}`;
    }).join("")}
  ${c('div')}
  <div id="newBox" class="card" style="display:none">
    <form method="post" action="/create">
      <input name="title" placeholder="标题" required>
      <input name="category" placeholder="分类">
      <input name="tags" placeholder="标签">
      <textarea name="content" placeholder="Markdown 内容..."></textarea>
      <div style="margin-top:14px; display:flex; gap:10px">
        <button class="btn-primary" style="flex:1">保存并预览</button>
        <button type="button" class="btn-ghost" onclick="toggleNew()" style="flex:1">取消</button>
      ${c('div')}
    </form>
  ${c('div')}
  <div id="docList" class="list">
    ${docs.map(d => `
      <div class="doc-item">
        <div class="title-line">
          ${d.pinned === 1 ? `<span style="color:#f59e0b">📌${c('span')}` : ''}
          <a class="title" href="/view?id=${d.id}">${d.title}${c('a')}
          <div class="tags">
            ${(d.tags||"").split(",").filter(Boolean).slice(0,2).map(t => `<span class="tag">${t.trim()}${c('span')}`).join("")}
          ${c('div')}
        ${c('div')}
        <div class="actions">
          <a href="/pin?id=${d.id}">${d.pinned === 1 ? '⭐' : '☆'}${c('a')}
          <a href="/edit?id=${d.id}">✏️${c('a')}
          <a href="/delete?id=${d.id}" onclick="return confirm('确定删除？')">🗑️${c('a')}
        ${c('div')}
      ${c('div')}
    `).join("")}
  ${c('div')}
${c('div')}
<script>
let isGrid = false;
function toggleNew() {
  const b = document.getElementById('newBox');
  b.style.display = b.style.display === 'none' ? 'block' : 'none';
}
function toggleLayout() {
  isGrid = !isGrid;
  document.getElementById('docList').className = isGrid ? 'grid' : 'list';
}
</script>`;
}

function viewPage(d) {
  const c = (tag) => `<\u002f${tag}>`;
  return `${baseStyle()}
<div class="container">
  <div class="card">
    <h1 style="margin:0 0 10px 0;">${d.title}${c('h1')}
    <div style="font-size:12.5px; color:#666; margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:10px;">
      ${d.category ? `分类: ${d.category}` : '未分类'}
    ${c('div')}
    <div class="view-content">${md(d.content)}${c('div')}
    <div style="margin-top:25px; border-top:1px solid #eee; padding-top:15px; display:flex; gap:15px; align-items:center;">
      <a href="/" style="color:var(--primary); text-decoration:none; font-weight:550; font-size:13.5px;">← 返回首页${c('a')}
      <a href="/edit?id=${d.id}" style="color:var(--primary); text-decoration:none; font-weight:550; font-size:13.5px;">✏️ 编辑文档${c('a')}
    ${c('div')}
  ${c('div')}
${c('div')}`;
}

function editPage(d) {
  const c = (tag) => `<\u002f${tag}>`;
  return `${baseStyle()}
<div class="container">
  <div class="card">
    <h3 style="margin-top:0">编辑${c('h3')}
    <form method="post">
      <input name="title" value="${escape(d.title)}" required>
      <input name="category" value="${escape(d.category || '')}">
      <input name="tags" value="${escape(d.tags || '')}">
      <textarea name="content">${escape(d.content)}</textarea>
      <div style="margin-top:16px; display:flex; gap:12px">
        <button class="btn-primary" style="flex:2; padding:12px">保存并预览</button>
        <button type="button" class="btn-ghost" onclick="history.back()" style="flex:1">取消并返回</button>
      ${c('div')}
    </form>
  ${c('div')}
${c('div')}`;
}

function escape(s = "") {
  return s.replace(/[&<>"']/g, m => ({
    "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
  }[m]));
}
