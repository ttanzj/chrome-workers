export default {
  async fetch(req, env) {
    const url = new URL(req.url);
    const method = req.method;
    const PASSWORD = env.PASSWORD;

    const html = (b) =>
      new Response(`<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">${b}</html>`, { 
        headers: { "content-type": "text/html;charset=UTF-8" } 
      });

    const redirect = (to) =>
      new Response(null, { status: 302, headers: { Location: to } });

    const isLogin = () =>
      req.headers.get("cookie")?.includes("login=1");

    /* ---------- 登录 ---------- */
    if (url.pathname === "/login") {
      if (method === "POST") {
        const f = await req.formData();
        if (f.get("password") === PASSWORD) {
          return new Response("", {
            status: 302,
            headers: {
              "Set-Cookie": "login=1; Path=/; SameSite=Lax",
              Location: "/",
            },
          });
        }
        return html(loginPage("密码错误"));
      }
      return html(loginPage());
    }
    if (!isLogin()) return redirect("/login");

    /* ---------- 新建 ---------- */
    if (url.pathname === "/create" && method === "POST") {
      const f = await req.formData();
      const now = new Date().toISOString();
      const result = await env.DB.prepare(
        `INSERT INTO docs (title, category, tags, content, pinned, created_at, updated_at)
         VALUES (?, ?, ?, ?, 0, ?, ?) RETURNING id`
      ).bind(
        f.get("title"),
        f.get("category"),
        f.get("tags"),
        f.get("content"),
        now,
        now
      ).first();
      return redirect(`/view?id=${result.id}`);
    }

    /* ---------- 切换置顶 ---------- */
    if (url.pathname === "/pin") {
      const id = url.searchParams.get("id");
      await env.DB.prepare(
        `UPDATE docs 
         SET pinned = CASE WHEN pinned = 1 THEN 0 ELSE 1 END,
             updated_at = ?
         WHERE id = ?`
      ).bind(new Date().toISOString(), id).run();
      return redirect("/");
    }

    /* ---------- 删除 ---------- */
    if (url.pathname === "/delete") {
      await env.DB.prepare(`DELETE FROM docs WHERE id=?`)
        .bind(url.searchParams.get("id")).run();
      return redirect("/");
    }

    /* ---------- 查看 ---------- */
    if (url.pathname === "/view") {
      const doc = await env.DB.prepare(`SELECT * FROM docs WHERE id=?`)
        .bind(url.searchParams.get("id")).first();
      return html(viewPage(doc));
    }

    /* ---------- 编辑 ---------- */
    if (url.pathname === "/edit") {
      const id = url.searchParams.get("id");
      if (method === "POST") {
        const f = await req.formData();
        await env.DB.prepare(
          `UPDATE docs SET title=?, category=?, tags=?, content=?, updated_at=?
           WHERE id=?`
        ).bind(
          f.get("title"),
          f.get("category"),
          f.get("tags"),
          f.get("content"),
          new Date().toISOString(),
          id
        ).run();
        return redirect(`/view?id=${id}`);
      }
      const doc = await env.DB.prepare(`SELECT * FROM docs WHERE id=?`)
        .bind(id).first();
      return html(editPage(doc));
    }

    /* ---------- 首页 ---------- */
    const categoryFilter = url.searchParams.get("category") || "";
    const docs = await env.DB.prepare(`
      SELECT * FROM docs 
      WHERE (? = '' OR category = ?)
      ORDER BY pinned DESC, updated_at DESC
    `).bind(categoryFilter, categoryFilter).all();

    const categories = await env.DB.prepare(
      `SELECT DISTINCT category FROM docs 
       WHERE category IS NOT NULL AND category != '' 
       ORDER BY category`
    ).all();

    return html(indexPage(docs.results, categories.results, categoryFilter));
  },
};

/* ================= 增强型表格解析 ================= */
function parseTables(text) {
  const lines = text.split('\n');
  let result = [];
  let i = 0;

  while (i < lines.length) {
    const trimmedLine = lines[i].trim();
    if (trimmedLine.startsWith('|') && i + 1 < lines.length && lines[i+1].includes('|') && lines[i+1].includes('-')) {
      let tableLines = [];
      while (i < lines.length && lines[i].trim().includes('|')) {
        tableLines.push(lines[i]);
        i++;
      }

      let html = `<table style="border-collapse:collapse;width:100%;margin:8px 0;background:#fff;display:table;">`;
      const parseRow = (row) => row.split('|').filter((c, idx, arr) => (idx !== 0 && idx !== arr.length - 1) || c.trim());
      
      // Header
      html += `<thead><tr>`;
      parseRow(tableLines[0]).forEach(c => {
        html += `<th style="border:1px solid #ddd;padding:6px 10px;background:#f8fafc;text-align:left;">${c.trim()}</th>`;
      });
      html += `</tr></thead><tbody>`;
      
      // Body (Skip 0 and 1)
      for (let j = 2; j < tableLines.length; j++) {
        html += `<tr>`;
        parseRow(tableLines[j]).forEach(c => {
          // 此处单元格内容已是转义后的，可以直接放入
          html += `<td style="border:1px solid #ddd;padding:6px 10px;">${c.trim()}</td>`;
        });
        html += `</tr>`;
      }
      html += `</tbody></table>`;
      result.push(html);
    } else {
      result.push(lines[i]);
      i++;
    }
  }
  return result.join('\n');
}

/* ================= Markdown 核心解析 ================= */
function md(t) {
  // 1. 先进行 HTML 转义，防止 XSS，同时也让后续正则更安全
  let content = escape(t);

  // 2. 处理转义反斜杠 (保护被转义的符号)
  content = content.replace(/\\([*#_>`[\]()!|~-])/g, '%%ESC_$1%%');

  // 3. 处理代码块 (防止内部被解析)
  const codes = [];
  content = content.replace(/```([\s\S]*?)```/g, (m, p1) => {
    codes.push(p1);
    return `%%CODEBLOCK_${codes.length - 1}%%`;
  });

  // 4. 解析表格 (在换行符处理前)
  content = parseTables(content);

  // 5. 块级元素解析
  content = content
    .replace(/^\*\*\*$/gm, '<hr style="border:none;border-top:1px solid #ddd;margin:12px 0;">')
    .replace(/^###### (.*$)/gm, '<h6 style="margin:4px 0 2px 0;">$1</h6>')
    .replace(/^##### (.*$)/gm, '<h5 style="margin:5px 0 2px 0;">$1</h5>')
    .replace(/^#### (.*$)/gm, '<h4 style="margin:6px 0 3px 0;">$1</h4>')
    .replace(/^### (.*$)/gm, '<h3 style="margin:8px 0 4px 0;">$1</h3>')
    .replace(/^## (.*$)/gm, '<h2 style="margin:10px 0 5px 0;">$1</h2>')
    .replace(/^# (.*$)/gm, '<h1 style="margin:12px 0 7px 0;">$1</h1>')
    .replace(/^&gt;[ ]?(.*$)/gm, '<blockquote style="border-left:4px solid #ddd;padding:2px 12px;color:#666;margin:6px 0;background:#f9f9f9;">$1</blockquote>')
    .replace(/^\* (.*$)/gm, '<ul style="margin:2px 0;"><li style="margin:0;">$1</li></ul>')
    .replace(/^- (.*$)/gm, '<ul style="margin:2px 0;"><li style="margin:0;">$1</li></ul>')
    .replace(/<\/ul>\n<ul>/g, '');

  // 6. 行内元素解析
  content = content
    .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/~~(.*?)~~/g, '<del>$1</del>')
    .replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1" style="max-width:100%">')
    .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank">$1</a>')
    .replace(/`(.*?)`/g, '<code>$1</code>');

  // 7. 处理特殊字符还原 (注意此处还原被转义的 &amp;emsp;)
  content = content.replace(/&amp;emsp;/g, '&emsp;');

  // 8. 换行逻辑：先处理普通的 \n 为 <br>，同时保留用户手写的 &lt;br&gt;
  content = content.replace(/\n/g, "<br>").replace(/&lt;br&gt;/g, "<br>");

  // 9. 最后还原代码块和转义符
  content = content.replace(/%%CODEBLOCK_(\d+)%%/g, (m, p1) => `<pre><code>${codes[p1]}</code></pre>`);
  content = content.replace(/%%ESC_(.)%%/g, '$1');
  
  return content;
}

/* ================= 布局与样式 ================= */
function baseStyle() {
  return `
<style>
:root { --primary: #2563eb; --bg: #f4f6f8; --text: #1f2937; }
body { 
  margin: 0; 
  font-family: -apple-system, system-ui, sans-serif; 
  background: var(--bg); 
  color: var(--text); 
  -webkit-font-smoothing: antialiased; 
  line-height: 1.4; 
}
.container { max-width: 1000px; margin: 0 auto; padding: 20px; box-sizing: border-box; }

.view-content { 
  min-height: 450px; 
  word-wrap: break-word; 
  font-size: 15.5px;
}
/* 调整间距：段落间距仅比正常行高宽约 0.5 倍 */
.view-content p, 
.view-content div, 
.view-content blockquote { 
  margin: 0.25em 0; 
}
.view-content li {
  margin: 0.1em 0;
}
.view-content h1, .view-content h2, .view-content h3, .view-content h4 {
  margin-top: 0.7em;
  margin-bottom: 0.3em;
}

.view-content pre { 
  background: #f1f5f9; 
  padding: 12px; 
  border-radius: 8px; 
  overflow-x: auto; 
  font-family: monospace; 
  margin: 8px 0;
  line-height: 1.4;
}
.view-content table { margin: 10px 0; border-spacing: 0; display: table; }
.view-content ul, .view-content ol { margin: 0.2em 0 0.2em 25px; padding: 0; }

.login-wrapper { display: flex; align-items: center; justify-content: center; min-height: 100vh; width: 100%; box-sizing: border-box; }
.card { background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
.header h2 { margin: 0; font-size: 22px; }
button { padding: 8px 16px; font-size: 14px; border: none; border-radius: 8px; cursor: pointer; }
.btn-primary { background: var(--primary); color: #fff; }
.btn-ghost { background: #e5e7eb; color: #333; }
input, textarea { width: 100%; padding: 12px; font-size: 16px; margin-top: 8px; border-radius: 8px; border: 1px solid #d1d5db; box-sizing: border-box; }
textarea { min-height: 380px; line-height: 1.5; font-family: monospace; resize: vertical; }

.doc-item { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; transition: all 0.2s; overflow: hidden; }
.title { font-weight: 600; cursor: pointer; text-decoration: none; color: var(--text); }
.tag { background: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 4px; font-size: 11px; white-space: nowrap; }
.actions a { text-decoration: none; font-size: 18px; }
.list .doc-item { display: flex; align-items: center; padding: 10px 16px; gap: 12px; margin-bottom: 8px; }
.list .title-line { flex: 1; display: flex; align-items: center; gap: 8px; min-width: 0; }
.list .title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 15px; }
.list .actions { display: flex; gap: 15px; flex-shrink: 0; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 15px; }
.grid .doc-item { padding: 15px; display: flex; flex-direction: column; text-align: center; }
.grid .actions { margin-top: auto; padding-top: 12px; display: flex; justify-content: center; gap: 20px; }
.category-filter { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 15px; }
.category-btn { padding: 6px 12px; border-radius: 20px; font-size: 13px; background: #fff; border: 1px solid #e2e8f0; text-decoration: none; color: inherit; }
.category-btn.active { background: var(--primary); color: white; border-color: var(--primary); }

@media (max-width: 600px) {
  .container { padding: 10px; }
  .grid { grid-template-columns: 1fr 1fr; gap: 8px; }
  textarea { min-height: 300px; font-size: 14px; }
}
</style>`;
}

function loginPage(msg="") {
  return `${baseStyle()}
<div class="login-wrapper">
  <div class="card" style="width:100%; max-width:320px;">
    <h2 style="text-align:center; margin-bottom:20px">系统登录</h2>
    ${msg ? `<p style="color:red;text-align:center;font-size:14px">${msg}</p>` : ""}
    <form method="post">
      <input type="password" name="password" placeholder="密码" autofocus>
      <button class="btn-primary" style="width:100%;margin-top:16px;padding:12px">确认</button>
    </form>
  </div>
</div>`;
}

function indexPage(docs, categories, currentCategory) {
  const allCategories = [{category: ""}, ...categories];
  return `${baseStyle()}
<div class="container">
  <div class="header">
    <h2>📄 文档库</h2>
    <div style="display:flex; gap:8px">
      <button class="btn-ghost" onclick="toggleLayout()">布局</button>
      <button class="btn-primary" onclick="toggleNew()">+ 新建</button>
    </div>
  </div>
  <div class="category-filter">
    ${allCategories.map(c => {
      const cat = c.category || "";
      const active = cat === currentCategory ? "active" : "";
      return `<a href="?category=${encodeURIComponent(cat)}" class="category-btn ${active}">${cat || "全部"}</a>`;
    }).join("")}
  </div>
  <div id="newBox" class="card" style="display:none">
    <form method="post" action="/create">
      <input name="title" placeholder="标题" required>
      <input name="category" placeholder="分类">
      <input name="tags" placeholder="标签">
      <textarea name="content" placeholder="Markdown 内容..."></textarea>
      <div style="margin-top:14px; display:flex; gap:10px">
        <button class="btn-primary" style="flex:1">保存并预览</button>
        <button type="button" class="btn-ghost" onclick="toggleNew()" style="flex:1">取消</button>
      </div>
    </form>
  </div>
  <div id="docList" class="list">
    ${docs.map(d => `
      <div class="doc-item">
        <div class="title-line">
          ${d.pinned === 1 ? `<span style="color:#f59e0b">📌</span>` : ''}
          <a class="title" href="/view?id=${d.id}">${d.title}</a>
          <div class="tags">
            ${(d.tags||"").split(",").filter(Boolean).slice(0,2).map(t => `<span class="tag">${t.trim()}</span>`).join("")}
          </div>
        </div>
        <div class="actions">
          <a href="/pin?id=${d.id}">${d.pinned === 1 ? '⭐' : '☆'}</a>
          <a href="/edit?id=${d.id}">✏️</a>
          <a href="/delete?id=${d.id}" onclick="return confirm('确定删除？')">🗑️</a>
        </div>
      </div>
    `).join("")}
  </div>
</div>
<script>
let isGrid = false;
function toggleNew() {
  const b = document.getElementById('newBox');
  b.style.display = b.style.display === 'none' ? 'block' : 'none';
}
function toggleLayout() {
  isGrid = !isGrid;
  document.getElementById('docList').className = isGrid ? 'grid' : 'list';
}
</script>`;
}

function viewPage(d) {
  return `${baseStyle()}
<div class="container">
  <div class="card">
    <h1 style="margin:0 0 10px 0; font-size:1.6rem;">${d.title}</h1>
    <div style="font-size:13px; color:#666; margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:10px;">
      ${d.category ? `分类: ${d.category}` : '未分类'}
    </div>
    <div class="view-content">${md(d.content)}</div>
    <div style="margin-top:25px; border-top:1px solid #eee; padding-top:15px; display:flex; gap:15px; align-items:center;">
      <a href="/" style="color:var(--primary); text-decoration:none; font-weight:500;">← 返回首页</a>
      <a href="/edit?id=${d.id}" style="color:var(--primary); text-decoration:none; font-weight:500;">✏️ 编辑文档</a>
    </div>
  </div>
</div>`;
}

function editPage(d) {
  return `${baseStyle()}
<div class="container">
  <div class="card">
    <h3 style="margin-top:0">编辑</h3>
    <form method="post">
      <input name="title" value="${d.title}" required>
      <input name="category" value="${d.category || ''}">
      <input name="tags" value="${d.tags || ''}">
      <textarea name="content">${d.content}</textarea>
      <div style="margin-top:16px; display:flex; gap:12px">
        <button class="btn-primary" style="flex:2; padding:12px">保存并预览</button>
        <button type="button" class="btn-ghost" onclick="history.back()" style="flex:1">取消并返回</button>
      </div>
    </form>
  </div>
</div>`;
}

function escape(s = "") {
  return s.replace(/[&<>"']/g, m => ({
    "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
  }[m]));
}
