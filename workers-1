  // 并行抓取（使用 allSettled 防止单个失败影响整体）
  await Promise.allSettled(
    sites.map(site => processOneSite(site, uniqueStrings))
  );

  const content = [...uniqueStrings].join('\n');

  // 转 Base64
  const encoder = new TextEncoder();
  const bytes = encoder.encode(content);
  let binary = '';
  const len = bytes.byteLength;
  for (let i = 0; i < len; i++) {
    binary += String.fromCharCode(bytes[i]);
  }
  const base64 = btoa(binary);

  // 存入 KV，设置过期时间
  await PROXY_KV.put(CACHE_KEY, base64, { expirationTtl: CACHE_TTL_SECONDS });

  return new Response(base64, {
    headers: { 'Content-Type': 'text/plain; charset=utf-8' }
  });
}

async function processOneSite(site, set) {
  try {
    const resp = await fetch(site.url, { cf: { cacheTtl: 300 } }); // 源站缓存5分钟
    if (!resp.ok) return;

    let data;
    if (site.type === 'naive' || site.type === 'juicity' || site.type === 'mieru') {
      data = await resp.json().catch(() => ({}));
    } else {
      data = await resp.json().catch(() => ({}));
    }

    if (site.type === "hysteria") {
      processHysteria(data, set);
    } else if (site.type === "hysteria2") {
      processHysteria2(data, set);
    } else if (site.type === "xray") {
      processXray(data, set);
    } else if (site.type === "singbox") {
      processSingbox(data, set);
    } else if (site.type === "naive") {
      processNaive(data, set);
    } else if (site.type === "juicity") {
      processJuicity(data, set);
    } else if (site.type === "mieru") {
      processMieru(data, set);
    }
  } catch (e) {
    // 静默失败
  }
}

// 处理器函数（保持简单、安全，避免 undefined 崩溃）

function safeGet(obj, path, def = '') {
  try {
    return path.split('.').reduce((o, k) => o?.[k], obj) ?? def;
  } catch {
    return def;
  }
}

function processHysteria(data, set) {
  const server = safeGet(data, 'server');
  if (!server) return;
  const params = new URLSearchParams({
    upmbps: safeGet(data, 'up_mbps'),
    downmbps: safeGet(data, 'down_mbps'),
    auth: safeGet(data, 'auth_str'),
    insecure: '1',
    peer: safeGet(data, 'server_name'),
    alpn: safeGet(data, 'alpn')
  });
  set.add(`hysteria://${server}?${params}`);
}

function processHysteria2(data, set) {
  const auth = safeGet(data, 'auth', '');
  const server = safeGet(data, 'server');
  if (!server) return;
  const insecure = safeGet(data, 'tls.insecure') ? '1' : '0';
  const sni = safeGet(data, 'tls.sni', '');
  set.add(`hysteria2://${auth}@${server}?insecure=${insecure}&sni=${sni}`);
}

function processXray(data, set) {
  const ob = safeGet(data, 'outbounds.0');
  if (!ob) return;
  const vnext = safeGet(ob, 'settings.vnext.0');
  const user = safeGet(vnext, 'users.0');
  if (!user?.id || !vnext?.address) return;

  const stream = safeGet(ob, 'streamSettings', {});
  const tls = safeGet(stream, 'tlsSettings', {});
  const ws = safeGet(stream, 'wsSettings', {});
  const fp = tls.fingerprint || (tls.serverName ? 'chrome' : '');

  const params = new URLSearchParams({
    security: stream.security || 'none',
    sni: tls.serverName || '',
    fp,
    type: stream.network || 'tcp'
  });
  if (stream.network === 'ws') {
    params.set('path', safeGet(ws, 'path', ''));
    params.set('host', safeGet(ws, 'headers.Host', ''));
  }

  const link = `${ob.protocol}://${user.id}@${vnext.address}:${vnext.port}?${params}`;
  set.add(link);
}

function processSingbox(data, set) {
  const ob = safeGet(data, 'outbounds.0');
  if (!ob?.server || !ob?.server_port) return;
  const params = new URLSearchParams({
    upmbps: ob.up_mbps || '',
    downmbps: ob.down_mbps || '',
    auth: ob.auth_str || '',
    insecure: '1',
    peer: safeGet(ob, 'tls.server_name', ''),
    alpn: safeGet(ob, 'tls.alpn.0', '')
  });
  set.add(`hysteria://${ob.server}:${ob.server_port}?${params}`);
}

function processNaive(data, set) {
  const proxy = safeGet(data, 'proxy', '');
  if (proxy) set.add(proxy);
}

function processJuicity(data, set) {
  const server = safeGet(data, 'server', '');
  const port = safeGet(data, 'port', '') || safeGet(data, 'server_port', '');
  const uuid = safeGet(data, 'uuid', '') || safeGet(data, 'password', '');
  if (!server || !port || !uuid) return;
  const sni = safeGet(data, 'sni', '');
  const insecure = safeGet(data, 'allow_insecure') ? '1' : '0';
  const cc = safeGet(data, 'congestion_control', 'bbr');
  const params = new URLSearchParams({ sni, congestion_control: cc, alpn: 'h3', allow_insecure: insecure });
  set.add(`juicity://${uuid}@${server}:${port}?${params}`);
}

function processMieru(data, set) {
  try {
    const json = JSON.stringify(data);
    const b64 = btoa(unescape(encodeURIComponent(json)));
    set.add(`mieru://${b64}#mieru`);
  } catch {}
}
