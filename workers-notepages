const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Methods': 'GET, POST, PUT, DELETE, OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type',
};

function jsonResponse(data, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: { ...corsHeaders, 'Content-Type': 'application/json' }
  });
}

// 统一的密码校验辅助函数
function checkAuth(request, env) {
  const correctPassword = env.ACCESS_PASSWORD || 'admin123';
  const authHeader = request.headers.get('Authorization');
  return authHeader === correctPassword;
}

function getStoragePrefix(env) {
  let prefix = (env.STORAGE_PREFIX || 'notepages').trim();
  return prefix.endsWith('/') ? prefix : prefix + '/';
}

async function hmacSha256(key, data) {
  const encoder = new TextEncoder();
  const mac = await crypto.subtle.sign('HMAC', key, encoder.encode(data));
  return new Uint8Array(mac);
}

async function getSignatureKey(secretKey, dateStamp, region, service) {
  const kDate = await hmacSha256(
    await crypto.subtle.importKey('raw', new TextEncoder().encode('AWS4' + secretKey), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']),
    dateStamp
  );
  const kRegion = await hmacSha256(
    await crypto.subtle.importKey('raw', kDate, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']),
    region
  );
  const kService = await hmacSha256(
    await crypto.subtle.importKey('raw', kRegion, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']),
    service
  );
  const kSigning = await hmacSha256(
    await crypto.subtle.importKey('raw', kService, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']),
    'aws4_request'
  );
  return kSigning;
}

async function computeSha256(data) {
  const digest = await crypto.subtle.digest('SHA-256', data instanceof ArrayBuffer ? data : new TextEncoder().encode(data));
  return Array.from(new Uint8Array(digest)).map(b => b.toString(16).padStart(2, '0')).join('');
}

async function s3Request(env, method, key, options = {}) {
  const endpoint = Math.random() > 0.5 ? env.S3_ENDPOINT_BACKUP || env.S3_ENDPOINT : env.S3_ENDPOINT;
  const bucket = env.S3_BUCKET;
  const accessKey = env.S3_ACCESS_KEY;
  const secretKey = env.S3_SECRET_KEY;
  
  if (!endpoint || !bucket || !accessKey || !secretKey) {
    console.error('Missing S3 credentials');
    return { ok: false, status: 500 };
  }

  const fullKey = getStoragePrefix(env) + key;
  const baseEndpoint = endpoint.replace(/\/$/, '');
  const urlString = `${baseEndpoint}/${bucket}/${fullKey.split('/').map(encodeURIComponent).join('/')}`;
  
  const url = new URL(urlString);
  const host = url.host;
  
  let region = 'us-east-1';
  const regionMatch = host.match(/s3\.([a-z0-9-]+)\.backblazeb2\.com/);
  if (regionMatch) { region = regionMatch[1]; }
  
  const service = 's3';
  const date = new Date().toISOString().replace(/[:-]|\.\d{3}/g, '');
  const dateStamp = date.substring(0, 8);
  
  let payloadHash = 'UNSIGNED-PAYLOAD';
  if (options.body && typeof options.body === 'string') {
    try {
      payloadHash = await computeSha256(options.body);
    } catch (hashErr) {
      payloadHash = 'UNSIGNED-PAYLOAD';
    }
  }
  
  let canonicalUri = `/${bucket}/${fullKey.split('/').map(encodeURIComponent).join('/')}`;
  const canonicalHeaders = `host:${host}\nx-amz-content-sha256:${payloadHash}\nx-amz-date:${date}\n`;
  const signedHeaders = 'host;x-amz-content-sha256;x-amz-date';
  
  const canonicalRequest = [method, canonicalUri, '', canonicalHeaders, signedHeaders, payloadHash].join('\n');
  const scope = `${dateStamp}/${region}/${service}/aws4_request`;
  let canonicalRequestHash = await computeSha256(canonicalRequest);
  
  const stringToSign = ['AWS4-HMAC-SHA256', date, scope, canonicalRequestHash].join('\n');
  const signingKey = await getSignatureKey(secretKey, dateStamp, region, service);
  const signatureArray = await hmacSha256(
    await crypto.subtle.importKey('raw', signingKey, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']),
    stringToSign
  );
  const signatureHex = Array.from(signatureArray).map(b => b.toString(16).padStart(2, '0')).join('');
  const authorization = `AWS4-HMAC-SHA256 Credential=${accessKey}/${scope}, SignedHeaders=${signedHeaders}, Signature=${signatureHex}`;
  
  const headers = new Headers({
    'Host': host,
    'X-Amz-Date': date,
    'X-Amz-Content-Sha256': payloadHash,
    'Authorization': authorization
  });
  
  if (options.contentType) { headers.set('Content-Type', options.contentType); }
  const requestOptions = { method, headers };
  if (options.body) { requestOptions.body = options.body; }
  
  try {
    return await fetch(url.toString(), requestOptions);
  } catch (error) {
    return { ok: false, status: 500 };
  }
}

async function getIndexList(env, type) {
  const res = await s3Request(env, 'GET', `${type}_index.json`);
  if (!res.ok) return [];
  try {
    const text = await res.text();
    return JSON.parse(text);
  } catch {
    return [];
  }
}

async function saveIndexList(env, type, list) {
  await s3Request(env, 'PUT', `${type}_index.json`, {
    body: JSON.stringify(list),
    contentType: 'application/json'
  });
}

async function handleNotes(request, env) {
  if (!checkAuth(request, env)) return jsonResponse({ error: 'Unauthorized' }, 401);
  
  const url = new URL(request.url);
  const path = url.pathname.replace('/api/notes', '');

  if (request.method === 'GET' && path === '') {
    const notes = await getIndexList(env, 'notes');
    return jsonResponse(notes);
  }

  if (request.method === 'PUT' && path === '/reorder') {
    const body = await request.json();
    if (Array.isArray(body.notes)) {
      await saveIndexList(env, 'notes', body.notes);
      return jsonResponse({ success: true });
    }
    return jsonResponse({ error: 'Invalid data' }, 400);
  }

  if (request.method === 'POST') {
    const body = await request.json();
    const note = {
      id: body.id || Date.now().toString(),
      title: body.title || '新建笔记',
      content: body.content || '',
      createdAt: body.createdAt || new Date().toISOString(),
      updatedAt: new Date().toISOString()
    };
    
    const putResponse = await s3Request(env, 'PUT', `notes/${note.id}`, { 
      body: JSON.stringify(note), 
      contentType: 'application/json' 
    });
    if (!putResponse.ok) return jsonResponse({ error: 'Save failed' }, 500);
    
    const notes = await getIndexList(env, 'notes');
    const summary = { id: note.id, title: note.title, createdAt: note.createdAt, updatedAt: note.updatedAt };
    const idx = notes.findIndex(n => n.id === note.id);
    if (idx > -1) notes[idx] = summary; else notes.unshift(summary);
    await saveIndexList(env, 'notes', notes);
    
    return jsonResponse(note);
  }

  if (request.method === 'GET' && path) {
    const noteId = path.slice(1);
    const response = await s3Request(env, 'GET', `notes/${noteId}`);
    if (response.ok) {
      try {
        const text = await response.text();
        const noteData = JSON.parse(text);
        return jsonResponse(noteData);
      } catch {
        return jsonResponse({ id: noteId, title: '未命名', content: '', updatedAt: new Date().toISOString() });
      }
    }
    return jsonResponse({ error: 'Note not found' }, 404);
  }

  if (request.method === 'PUT' && path) {
    const noteId = path.slice(1);
    const body = await request.json();
    
    const updated = {
      id: noteId,
      title: body.title || '无标题',
      content: body.content || '',
      createdAt: body.createdAt || new Date().toISOString(),
      updatedAt: new Date().toISOString()
    };
    
    const putResponse = await s3Request(env, 'PUT', `notes/${noteId}`, { 
      body: JSON.stringify(updated), 
      contentType: 'application/json' 
    });
    if (!putResponse.ok) return jsonResponse({ error: 'Update failed' }, 500);
    
    const notes = await getIndexList(env, 'notes');
    const summary = { id: updated.id, title: updated.title, createdAt: updated.createdAt, updatedAt: updated.updatedAt };
    const idx = notes.findIndex(n => n.id === noteId);
    if (idx > -1) notes[idx] = summary; else notes.push(summary);
    await saveIndexList(env, 'notes', notes);
    
    return jsonResponse(updated);
  }

  if (request.method === 'DELETE' && path) {
    const noteId = path.slice(1);
    await s3Request(env, 'DELETE', `notes/${noteId}`);
    
    const notes = await getIndexList(env, 'notes');
    const filtered = notes.filter(n => n.id !== noteId);
    await saveIndexList(env, 'notes', filtered);
    
    return jsonResponse({ success: true });
  }

  return jsonResponse({ error: 'Method not allowed' }, 405);
}

async function handleFiles(request, env) {
  if (!checkAuth(request, env)) return jsonResponse({ error: 'Unauthorized' }, 401);

  const url = new URL(request.url);
  const path = url.pathname.replace('/api/files', '');

  if (request.method === 'GET' && path === '') {
    const files = await getIndexList(env, 'files');
    files.sort((a, b) => new Date(b.uploadedAt) - new Date(a.uploadedAt));
    return jsonResponse(files);
  }

  if (request.method === 'POST') {
    const formData = await request.formData();
    const file = formData.get('file');
    if (!file) return jsonResponse({ error: 'No file provided' }, 400);

    const fileId = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g, '_')}`;
    const fileKey = `files/${fileId}`;
    
    const arrayBuffer = await file.arrayBuffer();
    const putResponse = await s3Request(env, 'PUT', fileKey, { 
      body: arrayBuffer, 
      contentType: file.type || 'application/octet-stream' 
    });
    
    if (!putResponse.ok) return jsonResponse({ error: 'Upload failed' }, 500);
    
    const meta = { id: fileId, name: file.name, size: file.size, type: file.type, uploadedAt: new Date().toISOString() };
    const files = await getIndexList(env, 'files');
    files.push(meta);
    await saveIndexList(env, 'files', files);
    
    return jsonResponse(meta);
  }

  if (request.method === 'DELETE' && path) {
    const fileId = path.slice(1);
    await s3Request(env, 'DELETE', `files/${fileId}`);
    
    const files = await getIndexList(env, 'files');
    const filtered = files.filter(f => f.id !== fileId);
    await saveIndexList(env, 'files', filtered);
    
    return jsonResponse({ success: true });
  }

  return jsonResponse({ error: 'Method not allowed' }, 405);
}

// 保持独立下载逻辑无视密码限制
async function handleDownload(request, env) {
  const url = new URL(request.url);
  const fileId = url.pathname.split('/').pop();
  
  const fileResponse = await s3Request(env, 'GET', `files/${fileId}`);
  if (!fileResponse.ok) return new Response('File not found', { status: 404 });

  const files = await getIndexList(env, 'files');
  const meta = files.find(f => f.id === fileId);

  const headers = new Headers(corsHeaders);
  headers.set('Content-Type', meta?.type || 'application/octet-stream');
  headers.set('Content-Disposition', `attachment; filename="${encodeURIComponent(meta?.name || fileId)}"`);
  
  return new Response(fileResponse.body, { headers });
}

