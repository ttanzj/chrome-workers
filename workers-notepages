        let draggingElement = null;

        function handleDragStart(e) {
            draggingElement = this;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        }

        function handleDragOver(e) {
            e.preventDefault();
            const list = $('notesList');
            const afterElement = getDragAfterElement(list, e.clientY);
            if (afterElement == null) {
                list.appendChild(draggingElement);
            } else {
                list.insertBefore(draggingElement, afterElement);
            }
        }

        async function handleDragEnd() {
            this.classList.remove('dragging');
            draggingElement = null;
            
            const currentItems = Array.from($('notesList').querySelectorAll('.note-item'));
            const newOrderedNotes = currentItems.map(item => {
                const id = item.getAttribute('data-id');
                return state.notes.find(n => n.id === id);
            }).filter(Boolean);
            
            state.notes = newOrderedNotes;
            
            try {
                await authenticatedFetch(API_BASE + '/api/notes/reorder', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ notes: state.notes })
                });
            } catch (err) {
                console.error('保存排序失败:', err);
            }
        }

        function getDragAfterElement(container, y) {
            const draggableElements = [...container.querySelectorAll('.note-item:not(.dragging)')];
            return draggableElements.reduce((closest, child) => {
                const box = child.getBoundingClientRect();
                const offset = y - box.top - box.height / 2;
                if (offset < 0 && offset > closest.offset) {
                    return { offset: offset, element: child };
                } else {
                    return closest;
                }
            }, { offset: Number.NEGATIVE_INFINITY }).element;
        }
        
        async function deleteNote(id) {
            if (!confirm('确定要删除该笔记吗？')) return;
            try {
                const res = await authenticatedFetch(API_BASE + '/api/notes/' + id, { method: 'DELETE' });
                if (res.ok) {
                    if (state.currentNote && state.currentNote.id === id) {
                        state.currentNote = null;
                        $('editorEmpty').style.display = 'flex';
                        $('editorContent').style.display = 'none';
                    }
                    await loadNotes();
                } else {
                    alert('删除失败');
                }
            } catch (e) {
                console.error(e);
                alert('删除失败');
            }
        }
        
        function renderFiles() {
            const list = $('filesList');
            list.innerHTML = '';
            
            if (state.files.length === 0) {
                list.innerHTML = '<div class="empty" style="grid-column:1/-1;"><div style="font-size:48px;margin-bottom:12px;">📤</div><p>暂无上传的文件</p></div>';
                return;
            }
            
            state.files.forEach(file => {
                const div = document.createElement('div');
                div.className = 'file-card';
                const size = file.size < 1024 ? file.size + ' B' : file.size < 1048576 ? (file.size / 1024).toFixed(1) + ' KB' : (file.size / 1048576).toFixed(1) + ' MB';
                div.innerHTML = '<div style="font-size:24px;margin-bottom:8px;">📄</div><div class="note-title">' + file.name + '</div><div style="font-size:12px;color:#999;display:flex;gap:12px;"><span>' + size + '</span><span>' + new Date(file.uploadedAt).toLocaleString('zh-CN') + '</span></div><div style="margin-top:12px;display:flex;gap:8px;justify-content:flex-end;"><button class="btn btn-default" onclick="copyLink(\\'' + file.id + '\\')">复制链接</button><button class="btn btn-primary" onclick="window.open(\\'' + API_BASE + '/download/' + file.id + '\\')">下载</button><button class="btn btn-danger" onclick="deleteFile(\\'' + file.id + '\\')">删除</button></div>';
                list.appendChild(div);
            });
        }
        
        window.createNote = async function() {
            const note = {
                id: Date.now().toString(),
                title: '新建笔记 ' + (state.notes.length + 1),
                content: '',
                createdAt: new Date().toISOString(),
                updatedAt: new Date().toISOString()
            };
            
            try {
                const res = await authenticatedFetch(API_BASE + '/api/notes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(note)
                });
                if (res.ok) {
                    await loadNotes();
                    selectNoteById(note.id);
                } else {
                    alert('创建失败');
                }
            } catch (e) { alert('创建失败'); }
        }
        
        async function selectNoteById(id) {
            try {
                const res = await authenticatedFetch(API_BASE + '/api/notes/' + id);
                if (res.ok) {
                    const fullNote = await res.json();
                    state.currentNote = fullNote;
                    
                    $('editorEmpty').style.display = 'none';
                    $('editorContent').style.display = 'flex';
                    $('noteTitle').value = fullNote.title;
                    $('noteContent').value = fullNote.content || '';
                    $('charCount').textContent = (fullNote.content || '').length + ' 字符';
                    $('lastSaved').textContent = '已保存';
                    $('lastSaved').className = 'status saved';
                    
                    const items = document.querySelectorAll('.note-item');
                    items.forEach((item) => {
                        if(item.getAttribute('data-id') === id) {
                            item.classList.add('active');
                        } else {
                            item.classList.remove('active');
                        }
                    });
                }
            } catch (e) {
                console.error('拉取笔记详情失败:', e);
            }
        }
        
        function markAsUnsaved() {
            if (!state.currentNote) return;
            $('lastSaved').textContent = '有修改未保存';
            $('lastSaved').className = 'status unsaved';
        }
        
        async function saveNote() {
            if (!state.currentNote) return;
            
            $('lastSaved').textContent = '保存中...';
            $('lastSaved').className = 'status saving';
            
            const updated = {
                ...state.currentNote,
                title: $('noteTitle').value,
                content: $('noteContent').value,
                updatedAt: new Date().toISOString()
            };
            
            try {
                const res = await authenticatedFetch(API_BASE + '/api/notes/' + updated.id, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updated)
                });
                if (res.ok) {
                    state.currentNote = updated;
                    const oldId = updated.id;
                    await loadNotes();
                    const items = document.querySelectorAll('.note-item');
                    items.forEach((item) => {
                        if(item.getAttribute('data-id') === oldId) {
                            item.classList.add('active');
                        }
                    });
                    $('lastSaved').textContent = '已保存';
                    $('lastSaved').className = 'status saved';
                } else {
                    $('lastSaved').textContent = '保存失败';
                    $('lastSaved').className = 'status';
                }
            } catch (e) { 
                $('lastSaved').textContent = '保存失败';
                $('lastSaved').className = 'status';
            }
        }
        
        window.deleteFile = async function(id) {
            if (!confirm('确定删除？')) return;
            try {
                const res = await authenticatedFetch(API_BASE + '/api/files/' + id, { method: 'DELETE' });
                if (res.ok) await loadFiles();
            } catch (e) { console.error(e); }
        }
        
        window.copyLink = async function(id) {
            await navigator.clipboard.writeText(window.location.origin + API_BASE + '/download/' + id);
            alert('链接已复制！');
        }
        
        function uploadFileWithProgress(file) {
            if (!file) return;
            
            const formData = new FormData();
            formData.append('file', file);
            
            $('uploadArea').classList.add('uploading');
            $('uploadTextPrompt').textContent = '正在处理文件: ' + file.name;
            $('progressContainer').style.display = 'block';
            $('progressText').style.display = 'block';
            $('progressBar').style.width = '0%';
            $('progressText').textContent = '0%';
            
            const xhr = new XMLHttpRequest();
            xhr.open('POST', API_BASE + '/api/files', true);
            
            // 附带认证密码
            const pwd = localStorage.getItem('notepages_pwd') || '';
            xhr.setRequestHeader('Authorization', pwd);
            
            xhr.upload.addEventListener('progress', function(event) {
                if (event.lengthComputable) {
                    const percent = Math.round((event.loaded / event.total) * 100);
                    const displayPercent = Math.min(percent, 95);
                    $('progressBar').style.width = displayPercent + '%';
                    $('progressText').textContent = displayPercent + '%';
                }
            });
            
            xhr.onload = function() {
                if (xhr.status === 401) { triggerLogout(); return; }
                if (xhr.status >= 200 && xhr.status < 300) {
                    $('progressBar').style.width = '100%';
                    $('progressText').textContent = '100% 上传完成';
                    setTimeout(() => {
                        resetUploadUI();
                        loadFiles();
                    }, 600);
                } else {
                    resetUploadUI();
                    alert('服务器存储失败');
                }
            };
            
            xhr.onerror = function() {
                resetUploadUI();
                alert('网络异常，上传中断');
            };
            
            xhr.send(formData);
        }
        
        function resetUploadUI() {
            $('uploadArea').classList.remove('uploading');
            $('uploadTextPrompt').textContent = '点击或拖拽文件到此处上传';
            $('progressContainer').style.display = 'none';
            $('progressText').style.display = 'none';
            $('progressBar').style.width = '0%';
            $('fileInput').value = '';
        }

        // 核心：密码验证流机制
        async function attemptLogin() {
            const inputPwd = $('passwordInput').value;
            if(!inputPwd) return;

            // 预测试拉取，验证输入的密码是否有效
            const res = await fetch(API_BASE + '/api/notes', {
                headers: { 'Authorization': inputPwd }
            });

            if (res.status === 401) {
                alert('密码错误，拒绝访问！');
                $('passwordInput').value = '';
                $('passwordInput').focus();
            } else if (res.ok) {
                localStorage.setItem('notepages_pwd', inputPwd);
                $('loginOverlay').style.display = 'none';
                // 验证成功，初次加载受保护数据
                loadNotes();
                loadFiles();
            } else {
                alert('服务器内部异常');
            }
        }

        function triggerLogout() {
            localStorage.removeItem('notepages_pwd');
            state.notes = [];
            state.files = [];
            state.currentNote = null;
            $('notesList').innerHTML = '';
            $('filesList').innerHTML = '';
            $('editorEmpty').style.display = 'flex';
            $('editorContent').style.display = 'none';
            $('passwordInput').value = '';
            $('loginOverlay').style.display = 'flex';
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            // 初始化密码检查
            const savedPwd = localStorage.getItem('notepages_pwd');
            if (savedPwd) {
                $('loginOverlay').style.display = 'none';
                loadNotes();
                loadFiles();
            } else {
                $('loginOverlay').style.display = 'flex';
                $('passwordInput').focus();
            }

            // 绑定登录事件
            $('loginBtn').onclick = attemptLogin;
            $('passwordInput').onkeydown = function(e) { if(e.key === 'Enter') attemptLogin(); };
            $('logoutBtn').onclick = function() {
                if(confirm('确定注销并退出本次登录吗？')) { triggerLogout(); }
            };

            $('navNotes').onclick = function() { switchTab('notes'); };
            $('navFiles').onclick = function() { switchTab('files'); };
            $('addNoteBtn').onclick = createNote;
            $('saveNoteBtn').onclick = saveNote;
            
            $('noteTitle').oninput = markAsUnsaved;
            $('noteContent').oninput = function() {
                $('charCount').textContent = $('noteContent').value.length + ' 字符';
                markAsUnsaved();
            };
            
            $('uploadArea').onclick = function() { 
                if (!$('uploadArea').classList.contains('uploading')) {
                    $('fileInput').click(); 
                }
            };
            
            $('fileInput').onchange = function(e) {
                const file = e.target.files?.[0];
                uploadFileWithProgress(file);
            };
            
            const box = $('uploadArea');
            box.addEventListener('dragover', (e) => { e.preventDefault(); });
            box.addEventListener('drop', (e) => {
                e.preventDefault();
                if (!box.classList.contains('uploading')) {
                    const file = e.dataTransfer.files?.[0];
                    uploadFileWithProgress(file);
                }
            });
        });
    </script>
</body>
</html>`;

export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    if (request.method === 'OPTIONS') {
      return new Response(null, { headers: corsHeaders });
    }
    if (url.pathname.startsWith('/api/notes')) {
      return handleNotes(request, env);
    }
    if (url.pathname.startsWith('/api/files')) {
      return handleFiles(request, env);
    }
    // 下载链接：绕过密码鉴权处理器
    if (url.pathname.startsWith('/download/')) {
      return handleDownload(request, env);
    }
    return new Response(HTML, { headers: { 'Content-Type': 'text/html; charset=utf-8' } });
  }
};
